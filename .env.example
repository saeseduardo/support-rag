# ── PROVEEDOR DE IA ─────────────────────────────────────────────────────────
# Cambia AI_PROVIDER para cambiar de proveedor. Solo esta linea.
# Opciones: gemini | openai
AI_PROVIDER=gemini

# ── GEMINI (activo por defecto) ──────────────────────────────────────────────
GEMINI_API_KEY=AIza...
LLM_MODEL=gemini-2.0-flash
EMBEDDING_MODEL=models/text-embedding-004
EMBEDDING_DIMENSIONS=768

# ── OPENAI (descomentar si AI_PROVIDER=openai) ───────────────────────────────
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

# ── BASE DE DATOS ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://dev:dev@localhost:5432/supportrag

# ── REDIS ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── COHERE (Sprint 2) ────────────────────────────────────────────────────────
# COHERE_API_KEY=...

# ── LANGFUSE (Sprint 3) ──────────────────────────────────────────────────────
# LANGFUSE_PUBLIC_KEY=...
# LANGFUSE_SECRET_KEY=...
